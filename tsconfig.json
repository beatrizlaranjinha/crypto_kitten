{
  "compilerOptions": {
    "target": "es2020",
    "module": "commonjs",
    "moduleResolution": "node10",
    "rootDir": ".",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "types": ["node"],
    "strict": false,
    "skipLibCheck": true,
    "ignoreDeprecations": "6.0"
  },
  "include": ["scripts/**/*.ts"]
}
